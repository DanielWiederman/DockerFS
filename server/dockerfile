# בוחרים גרסת Node קלה
FROM node:18-alpine

# מגדירים את תיקיית העבודה בתוך הקונטיינר
WORKDIR /app

# מעתיקים קודם את קובצי ההגדרות כדי להתקין ספריות
COPY package*.json ./
RUN npm install

# מעתיקים את שאר הקוד
COPY . .

# חושפים את הפורט (תואם למה שהגדרת ב-compose)
EXPOSE 5000

# הפקודה שמריצה את השרת (שנה את זה אם הפקודה שלך היא start ולא dev)
CMD ["npm", "run", "dev"]